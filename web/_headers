# Netlify _headers — security headers applied to every response.
# Per the EQ Intake bundle's standing rules: "All Netlify/CF Pages apps need
# _headers file with security headers."
#
# This file is processed by Netlify only. flutter build web copies it
# verbatim into build/web/ because the entry is anything not starting with
# a Flutter-managed name (index.html, main.dart.js, etc.).

/*
  # X-Frame-Options removed 2026-05-20 to allow eq-shell at <tenant>.eq.solutions
  # to iframe-embed Cards at /:tenant/cards. CSP frame-ancestors below is the
  # modern, granular replacement — it scopes embedding to *.eq.solutions only.
  # X-Frame-Options can't express that ("ALLOW-FROM" is deprecated and poorly
  # supported) so leaving it out is correct, not a regression.
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(self), microphone=(), geolocation=(), interest-cohort=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  X-XSS-Protection: 0
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Resource-Policy: same-origin

# Content-Security-Policy. Tight enough to block injection; loose enough
# that the production app actually works. Domains explicitly enumerated:
#   - 'self' for the Netlify origin
#   - https://www.gstatic.com — Flutter CanvasKit renderer (loaded at runtime)
#   - https://fonts.gstatic.com — Roboto font fetched by CanvasKit
#   - https://fonts.googleapis.com — Google Fonts CSS shim
#   - jvknxcmbtrfnxfrwfimn.supabase.co — eq-canonical Supabase
#   - https://core.eq.solutions — Shell handoff: phone-OTP → tenant_id exchange
#     (shell-login-phone-otp) and the shell-verify mint. Without it the browser
#     blocks the exchange, the JWT carries no tenant_id, and sign-in dead-ends
#     on the not-provisioned screen.
#   - https://eu.i.posthog.com / eu-assets — PostHog ingest + SDK helpers
#   - https://*.sentry.io — Sentry envelope ingestion (US/EU regions)
#   - https://browser.sentry-cdn.com — Sentry web SDK bundle (script-src); without
#     it the loader is CSP-blocked and breadcrumbs/errors never reach Sentry on web
#
# 'unsafe-inline' on script-src is required by Flutter's bootstrap (inline
# script injects flutter_bootstrap.js). 'unsafe-eval' is required by DDC in
# debug builds and by CanvasKit; release builds still need it for CanvasKit.
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://www.gstatic.com https://eu.i.posthog.com https://eu-assets.i.posthog.com https://browser.sentry-cdn.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' data: https://fonts.gstatic.com; img-src 'self' blob: data: https://www.gstatic.com https://jvknxcmbtrfnxfrwfimn.supabase.co; connect-src 'self' blob: data: https://www.gstatic.com https://fonts.gstatic.com https://fonts.googleapis.com https://jvknxcmbtrfnxfrwfimn.supabase.co wss://jvknxcmbtrfnxfrwfimn.supabase.co https://core.eq.solutions https://eu.i.posthog.com https://eu-assets.i.posthog.com https://*.sentry.io; manifest-src 'self'; worker-src 'self' blob:; frame-ancestors 'self' https://*.eq.solutions

# main.dart.js is NOT content-addressed (same filename across builds), so
# immutable would cause browsers to serve a stale build indefinitely. Use
# no-cache so every load revalidates against the CDN (304 if unchanged).
/
  Cache-Control: public, max-age=0, must-revalidate
/main.dart.js
  Cache-Control: public, no-cache, must-revalidate
/flutter_service_worker.js
  Cache-Control: public, max-age=0, must-revalidate
/index.html
  Cache-Control: public, max-age=0, must-revalidate
